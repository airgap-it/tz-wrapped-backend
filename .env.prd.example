# Copy to .env on the deploy server (papers-h-9:/home/papers/tz-wrapped-backend/.env).
# CI overwrites IMAGE_TAG on each deploy; the rest you set once.

# GitLab container registry repo = $CI_REGISTRY_IMAGE (NO image name appended;
# compose adds /tz-wrapped-backend). + tag (CI sed's IMAGE_TAG on deploy).
IMAGE_REGISTRY=registry.gitlab.papers.tech/papers/customer-tezos-foundation/tz-wrapped/tz-wrapped-backend
IMAGE_TAG=latest

# Host port the backend is published on (external reverse proxy targets it).
HOST_PORT=9003

# Public domain (k8s prod: tz-wrapped.prod.gke.papers.tech / foundry-backend.wrappedtz.io).
TZW_SERVER__DOMAIN_NAME=foundry-backend.wrappedtz.io

# Database (bundled postgres uses these too; host is fixed to the compose service).
TZW_DATABASE__NAME=tz_wrapped_prod
TZW_DATABASE__USER=tzwrapped
TZW_DATABASE__PASSWORD=__CHANGE_ME__

# SMTP (from k8s configmap + secret).
TZW_SMTP__HOST=__CHANGE_ME__
TZW_SMTP__USER=__CHANGE_ME__
TZW_SMTP__PASSWORD=__CHANGE_ME__
